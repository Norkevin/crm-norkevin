# Notion API token (crear en https://www.notion.so/my-integrations)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxx

# Flask secret (cualquier string random)
FLASK_SECRET=change-me-to-a-random-string

# Server port (opcional, default 5000 para Render)
PORT=5000

# Email delivery
# test = no envia correos reales; guarda en data/mail_outbox.json
# real = envia usando EMAIL_PROVIDER=smtp o EMAIL_PROVIDER=resend
EMAIL_DELIVERY_MODE=test
EMAIL_PROVIDER=local_outbox
MAIL_FROM=info@astralweddings.com

# SMTP real (activar con EMAIL_DELIVERY_MODE=real y EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASSWORD=change-me
SMTP_TLS=true

# Resend real (activar con EMAIL_DELIVERY_MODE=real y EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM=ASTRAL WEDDINGS <info@astralweddings.com>

# Gmail OAuth (conectar tu cuenta de Gmail real desde Settings > Email Settings)
# 1. Crea un OAuth Client ID tipo "Web application" en
#    https://console.cloud.google.com/apis/credentials (habilita la Gmail API primero)
# 2. Agrega como Authorized redirect URI la que te muestra Settings > Email Settings
#    (cambia si cambia el dominio/tunnel, hay que actualizarla en Google Cloud Console)
# 3. Pega el Client ID y Client Secret aqui
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Recurrente (links de pago) - obtene tu llave en Recurrente > Configuracion > Llaves API
RECURRENTE_SECRET_KEY=
