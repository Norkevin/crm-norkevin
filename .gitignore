# .gitignore - Norkevin CRM
# Cosas que NO deben commitearse

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual env
venv/
env/
ENV/
.venv/

# Configuracion con secrets
.env
*.env.local

# Logs
*.log
logs/

# IDEs
.vscode/
.idea/
*.swp

# Sistema
.DS_Store
Thumbs.db

# Backups
*.bak
*~
*.tmp

# Builds
build/
dist/

# Tests (mientras sean temporales)
.pytest_cache/
.coverage

# Wrangler / deploy temporal
.wrangler/

# SQLite local
*.db
data/*.db

# Datos reales del negocio -- nombres, emails, telefonos, pagos de clientes.
# Este repo es publico, esto NUNCA debe subirse.
data/

# Secrets de OAuth / archivos subidos por usuarios (nunca deben commitearse)
data/google_token.json
data/uploads/
